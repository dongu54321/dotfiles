<?xml version="1.0" encoding="utf-8"?>

<Patch>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Vanilla Weapons Expanded</li>
		</mods>

	<match Class="PatchOperationSequence">
		<success>Always</success>
            <!-- Hammer -->
			<operations>
				<li Class="PatchOperationReplace">
                    <!-- <xpath>/Defs/ThingDef[defName="VWE_MeleeWeapon_Hammer"]/subSounds/li/grains/li[clipFolderPath="Weapon/SniperRifle"]/clipFolderPath</xpath> -->
                    <xpath>/Defs/ThingDef[defName="VWE_MeleeWeapon_Hammer"]/equippedStatOffsets</xpath>
                    <value>
						<equippedStatOffsets> <!-- much stuff to choose from or to use it all -->
                            <ConstructionSpeed>0.21</ConstructionSpeed> <!-- 0.15 to 0.33 max, balanced -->
                            <ConstructSuccessChance>0.11</ConstructSuccessChance>
                            <GeneralLaborSpeed>0.05</GeneralLaborSpeed>
                        </equippedStatOffsets>
                    </value>
                </li>
			</operations>

            <!-- Axe Neolithic-->
            <operations>
				<li Class="PatchOperationReplace">
                    <xpath>/Defs/ThingDef[defName="VWE_MeleeWeapon_Axe"]/equippedStatOffsets</xpath>
                    <value>
						<equippedStatOffsets>
                            <PlantWorkSpeed>0.15</PlantWorkSpeed> <!-- 0.15 to 0.5 max, balanced out in comparison with other community tools in its category, some ppl went crazy here, effects harvesting too -->
                        </equippedStatOffsets>
                    </value>
                </li>
			</operations>

            <!-- Shovel VWE_MeleeWeapon_Shovel -->
            <operations>
				<li Class="PatchOperationReplace">
                    <xpath>/Defs/ThingDef[defName="VWE_MeleeWeapon_Shovel"]/equippedStatOffsets</xpath>
                    <value>
                        <equippedStatOffsets>
                            <MiningSpeed>0.15</MiningSpeed>
                            <PlantWorkSpeed>0.15</PlantWorkSpeed>
                            <PlantHarvestYield>0.15</PlantHarvestYield>	  <!-- 0.15 max, balanced out in comparison with other community tools in its category -->
                        </equippedStatOffsets>
                    </value>
                </li>
			</operations>
		</match>
	</Operation>

</Patch>