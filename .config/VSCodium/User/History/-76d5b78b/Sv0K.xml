<?xml version="1.0" encoding="utf-8"?>

<Patch>

	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>


			<!-- Increase feul-->
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "Apparel_handy_lantern"]/comps/li[@Class="Handy_Lantern.HL_CompProperties_LanternLight"]/fuelMax</xpath>
                <value>
                    <fuelMax>3</fuelMax>
                </value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "Apparel_handy_lantern_retro"]/comps/li[@Class="Handy_Lantern.HL_CompProperties_LanternLight"]/fuelMax</xpath>
                <value>
                    <fuelMax>3</fuelMax>
                </value>
			</li>            
            
			<!-- Change Layer-->
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "Apparel_handy_lantern"]/apparel/bodyPartGroups</xpath>
				<value>
					<li>giuahong</li>
				</value>
			</li>

			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "Apparel_handy_lantern_retro"]/apparel/bodyPartGroups</xpath>
				<value>
					<li>giuahong</li>
				</value>
			</li>

            <!-- Change light -->
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "Shining_bread_crumbs"]/comps/li[@Class="CompProperties_Glower"]/glowRadius</xpath>
				<value>
					<glowRadius>5</glowRadius>
				</value>
			</li>

			<!-- <li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "Shining_bread_crumbs"]/comps/li[@Class="CompProperties_Glower"]/glowColor</xpath>
				<value>
					<glowColor>(252,187,113,0)</glowColor>
				</value>
			</li> -->

            <li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "Shining_bread_crumbs"]/comps/li[@Class="CompProperties_Glower"]/overlightRadius</xpath>
				<value>
					<overlightRadius>0.6</overlightRadius>
				</value>
			</li>

		</operations>
	</Operation>
	
</Patch>