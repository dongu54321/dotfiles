<?xml version="1.0" encoding="utf-8"?>

<Patch>

	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>


			<!-- Remove Quality Furniture -->
			<li Class="PatchOperationAttributeSet">
				<xpath>/Defs/ThingDef[defName = "GardenBox"]</xpath>
				<attribute>ParentName</attribute>
                <value>FurnitureBase</value>
			</li>

			<!-- Reduce Cost -->
			<li Class="PatchOperationReplace">
				<xpath>/Defs/ThingDef[defName = "GardenBox"]/costStuffCount</xpath>
				<value>
					<costStuffCount>20</costStuffCount>
				</value>
			</li>
			<!-- Set Market value -->
            <li Class="PatchOperationAdd">
				<xpath>/Defs/ThingDef[defName = "GardenBox"]/statBases</xpath>
				<value>
					<MarketValue>5</MarketValue>
				</value>
			</li>

			<!-- Remove rice default -->
			<li Class="PatchOperationRemove">
				<xpath>/Defs/ThingDef[defName = "GardenBox"]/building/defaultPlantToGrow</xpath>
			</li>
            
			
		</operations>
	</Operation>
	
</Patch>