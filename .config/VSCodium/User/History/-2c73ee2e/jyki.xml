	<!-- Change size of trees scale -->
	
	<Operation Class= "PatchOperationSequence">
		<operations>
		
	<!-- Arid Trees -->
		
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.desertexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_JoshuaTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.3</visualSizeRange>
				</value>
			</li>
			
	<!-- Aspen Trees -->
			
			<li Class= "PatchOperationAdd" MayRequire="regrowth.botr.aspenforest">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeAspenRed"]/plant</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>
			
			<li Class= "PatchOperationAdd" MayRequire="regrowth.botr.aspenforest">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeAspenYellow"]/plant</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>
			
	<!-- Boiling Trees -->
	
			<li Class= "PatchOperationAdd" MayRequire="regrowth.botr.boilingforest">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeBoilingBirch"]/plant</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>	
			
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.boilingforest">
				<xpath>Defs/ThingDef[defName="RG_Plant_BoilingTreePine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~4.3</visualSizeRange>
				</value>
			</li>
			
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.boilingforest">
				<xpath>Defs/ThingDef[defName="RG_Plant_SpikedBoilingTreePine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~4.3</visualSizeRange>
				</value>
			</li>
					
	<!-- Boreal	Trees -->
				
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.borealforestexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_BlueTreePine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.9</visualSizeRange>
				</value>
			</li>
			
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.borealforestexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_LargeTreePine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~4.5</visualSizeRange>
				</value>
			</li>	
			
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.borealforestexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_OrangeTreePine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.9</visualSizeRange>
				</value>
			</li>
			
	<!-- Swamp Trees -->
				
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.swampexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeWhiteWillow"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.2</visualSizeRange>
				</value>
			</li>
			
	<!-- Temperate Trees -->
	
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.temperateforestexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeCornish"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>	
			
	<!-- Tropical Trees -->
	
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.tropicalexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_TallPalmTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~4.2</visualSizeRange>
				</value>
			</li>
	
			<li Class= "PatchOperationAdd" MayRequire="regrowth.botr.tropicalexpansion">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeDwarfPalm"]/plant</xpath>
				<value>
					<visualSizeRange>1.5~2.8</visualSizeRange>
				</value>
			</li>	

	<!-- Tundra trees -->
	
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.tundraexpansion">
				<xpath>Defs/ThingDef[defName="RG_Tree_TundraTreePine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~4.5</visualSizeRange>
				</value>
			</li>
			
	<!-- Wasteland trees -->
	
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.wastelands">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeSplitpine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~4.0</visualSizeRange>
				</value>
			</li>				
				
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.wastelands">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeToxipine"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~4.0</visualSizeRange>
				</value>
			</li>	
			
			<li Class= "PatchOperationReplace" MayRequire="regrowth.botr.wastelands">
				<xpath>Defs/ThingDef[defName="RG_Plant_TreeToxiTeak"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.1</visualSizeRange>
				</value>
			</li>
				
		</operations>		
	</Operation>	
			
</Patch>