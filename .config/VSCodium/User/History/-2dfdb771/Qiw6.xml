<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Power Tools</li>
        </mods>

        <match Class="PatchOperationSequence">
            <success>Always</success>
            <!-- PowerTool_IndustrialChainsaw -->
            <operations>
                
                <li Class="PatchOperationReplace">
                    <!-- <xpath>/Defs/ThingDef[defName="VWE_MeleeWeapon_Hammer"]/subSounds/li/grains/li[clipFolderPath="Weapon/SniperRifle"]/clipFolderPath</xpath> -->
                    <xpath>/Defs/ThingDef[defName="PowerTool_IndustrialChainsaw"]/equippedStatOffsets</xpath>
                    <value>
                        <equippedStatOffsets>
                            <PlantWorkSpeed>0.37</PlantWorkSpeed>
                            <PlantHarvestYield>0.07</PlantHarvestYield>
                            <MoveSpeed>-0.25</MoveSpeed>
                        </equippedStatOffsets>
                    </value>
                </li>

                <!-- PowerTool_IndustrialGrinder-->
                <li Class="PatchOperationReplace">
                    <xpath>/Defs/ThingDef[defName="PowerTool_IndustrialGrinder"]/equippedStatOffsets</xpath>
                    <value>
                        <equippedStatOffsets>
                            <ConstructionSpeed>0.37</ConstructionSpeed>
                            <ButcheryMechanoidEfficiency>0.25</ButcheryMechanoidEfficiency>
                            <ButcheryMechanoidSpeed>0.5</ButcheryMechanoidSpeed>
                            <MoveSpeed>-0.15</MoveSpeed>
                        </equippedStatOffsets>
                    </value>
                </li>

                <!-- JackHammer -->
                <li Class="PatchOperationReplace">
                    <xpath>/Defs/ThingDef[defName="PowerTool_IndustrialJackHammer"]/equippedStatOffsets</xpath>
                    <value>
                        <equippedStatOffsets>
                            <MiningSpeed>0.50</MiningSpeed>
                        </equippedStatOffsets>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>/Defs/ThingDef[defName="PowerTool_IndustrialDrill"]/equippedStatOffsets</xpath>
                    <value>
                        <equippedStatOffsets>
                            <GeneralLaborSpeed>0.37</GeneralLaborSpeed>
                            <ButcheryMechanoidEfficiency>0.11</ButcheryMechanoidEfficiency>
                            <ButcheryMechanoidSpeed>0.11</ButcheryMechanoidSpeed>
                        </equippedStatOffsets>
                    </value>
                </li>

            </operations>
        </match>
    </Operation>

</Patch>