jellyfin.moinin.duckdns.org {
	encode gzip
	import localTLS
	reverse_proxy http://127.0.0.1:8096
}

qbit.moinin.duckdns.org {
	import localTLS
	import secure *
	reverse_proxy http://127.0.0.1:16602
}

