<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="AdaptiveStorageBase">
		<defName>ReelStorageMedicineCabinet</defName>
		<label>medicine cabinet</label>
		<graphicData>
			<texPath>Tier4/Medicine/MedicineCabinet</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.8,2.8)</drawSize>
			<drawRotated>false</drawRotated>
		</graphicData>
		<uiIconScale>0.6</uiIconScale>
		<description>A compact shelf designed to hold medicine, body parts, drugs, and plant matter.
			Items stored inside will not deteriorate over time and have no impact on the beauty of
			their surroundings, however you will still need to freeze certain items.
			\n\n&lt;color=#E5E54C&gt;Storage stats:&lt;/color&gt;
			Stack size total: 18
			Stack per tile: 9

			Allowed items: Medicine, Plant Matter, Drugs, Neutroamine, Body parts
			\n\n&lt;color=#0094FF&gt;Items stored can be frozen if you have Simple Utilities: Fridge
			installed.&lt;/color&gt;</description>
		<fillPercent>0.20</fillPercent>
		<size>(1,1)</size>
		<rotatable>true</rotatable>
		<defaultPlacingRot>North</defaultPlacingRot>
		<researchPrerequisites>
			<li>ReelIndustrialStorage</li>
			<li>MedicineProduction</li>
		</researchPrerequisites>
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<WorkToBuild>2600</WorkToBuild>
			<Beauty>0</Beauty>
			<Mass>12</Mass>
			<Flammability>0</Flammability>
		</statBases>
		<costList>
			<Steel>85</Steel>
			<ComponentIndustrial>1</ComponentIndustrial>
		</costList>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>150</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable" />
			<li Class="CompProperties_Glower">
				<glowRadius>5</glowRadius>
				<glowColor>(200,255,255,0)</glowColor>
			</li>
		</comps>
		<modExtensions>
			<li MayRequire="owlchemist.fridgeutilities" Class="SimpleFridge.Fridge" />
		</modExtensions>
		<building>
			<preventDeteriorationOnTop>true</preventDeteriorationOnTop>
			<ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
			<maxItemsInCell>18</maxItemsInCell>
			<fixedStorageSettings>
				<filter>
					<specialFiltersToAllow>
						<li MayRequire="ludeon.rimworld.ideology">AllowVegetarian</li>
					</specialFiltersToAllow>
					<categories>
						<li>Medicine</li>
						<li>PlantMatter</li>
						<li>Drugs</li>
						<li>BodyParts</li>
					</categories>
					<thingDefs>
						<li MayRequire="ludeon.rimworld.biotech">HemogenPack</li>
						<li>Neutroamine</li>
					</thingDefs>
				</filter>
			</fixedStorageSettings>
			<defaultStorageSettings>
				<priority>Preferred</priority>
				<filter>
					<categories>
						<li>Medicine</li>
						<li>PlantMatter</li>
						<li>Drugs</li>
						<li>BodyParts</li>
					</categories>
					<thingDefs>
						<li MayRequire="ludeon.rimworld.biotech">HemogenPack</li>
						<li>Neutroamine</li>
					</thingDefs>
				</filter>
			</defaultStorageSettings>
			<paintable>false</paintable>
		</building>
		<minifiedDef>MinifiedThing</minifiedDef>
		<thingCategories>
			<li>BuildingsFurniture</li>
		</thingCategories>
	</ThingDef>
</Defs>