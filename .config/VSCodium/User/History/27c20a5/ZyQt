#!/bin/bash
#
# Script: convert-md-to-audio-mt.sh
# Mô tả: Chuyển đổi song song (multithread) các file .md thành audio (.mp3) & subtitle (.srt) dùng edge-tts.
#

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

show_help() {
    echo -e "${YELLOW}Sử dụng:${NC} $0 [-j SỐ_LUỒNG] [-d THƯ_MỤC]"
    echo "  -h, --help      Hiển thị trợ giúp"
    echo "  -d THƯ_MỤC      Thư mục nguồn (default: .)"
    echo "  -j SỐ_LUỒNG     Số tiến trình song song tối đa (default: 3)"
    echo
}
rm -f error.log
# Giá trị mặc định
TARGET_DIR="."
JOBS=3

# Xử lý tham số
while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        -d)
            shift
            TARGET_DIR="$1"
            ;;
        -j)
            shift
            JOBS="$1"
            ;;
        *)
            echo -e "${RED}Tham số không hợp lệ:${NC} $1"
            show_help
            exit 1
            ;;
    esac
    shift
done

if [ ! -d "$TARGET_DIR/text" ]; then
    echo -e "${RED}Lỗi:${NC} Không tìm thấy thư mục '$TARGET_DIR/text'." >&2
    exit 2
fi

mkdir -p "$TARGET_DIR/audio" "$TARGET_DIR/srt"

# Hàm xử lý 1 file
convert_one_md() {
    mdfile="$1"
    basename_noext="$(basename "$mdfile" .md)"
    audio_file="$TARGET_DIR/audio/${basename_noext}.mp3"
    srt_file="$TARGET_DIR/srt/${basename_noext}.srt"

    if [ ! -s "$mdfile" ]; then
        echo -e "${YELLOW}File rỗng, bỏ qua:${NC} $mdfile" >&2
        return
    fi

    text_input="${basename_noext}. $(cat "$mdfile")"

    max_attempts=5
    attempt=1
    while [ $attempt -le $max_attempts ]; do
        # Xoá file cũ trước khi thử lại
        [ -f "$audio_file" ] && rm -f "$audio_file"
        [ -f "$srt_file" ] && rm -f "$srt_file"

        if edge-tts --voice vi-VN-NamMinhNeural \
            --text "$text_input" \
            --write-media "$audio_file" \
            --write-subtitles "$srt_file" > /dev/null 2>&1; then
            echo -e "${GREEN}✔ Chuyển xong (${attempt}/$max_attempts):${NC} $(basename "$mdfile")"
            return 0
        else
            if [ $attempt -lt $max_attempts ]; then
                echo -e "${RED}✗ Lỗi lần $attempt với ${mdfile}, xoá file kết quả cũ và thử lại...${NC}"
                sleep 2
            else
                echo -e "${RED}✗ Lỗi sau $max_attempts lần thử:${NC} $mdfile"
                echo "✗ Lỗi sau $max_attempts lần thử: $mdfile" >> error.log
            fi
        fi
        attempt=$((attempt + 1))
    done
}

export -f convert_one_md
export TARGET_DIR

MD_LIST=$(find "$TARGET_DIR/text" -maxdepth 1 -type f -name '*.md')
COUNT=$(echo "$MD_LIST" | wc -l)
if [[ "$COUNT" -eq 0 ]]; then
    echo -e "${YELLOW}Không có file .md nào trong $TARGET_DIR/text${NC}"
    exit 0
fi

echo -e "${BLUE}Bắt đầu chuyển đổi $COUNT file với $JOBS luồng...${NC}"

# Sử dụng xargs song song nếu có
find "$TARGET_DIR/text" -maxdepth 1 -type f -name '*.md' -print0 | xargs -0 -n 1 -P "$JOBS" bash -c 'convert_one_md "$0"'

echo -e "${GREEN}Đã xử lý xong tất cả file.${NC}"
