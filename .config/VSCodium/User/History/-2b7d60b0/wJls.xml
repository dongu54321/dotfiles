	<!-- Change size of trees scale -->

	<Operation Class= "PatchOperationSequence">
		<operations>

			<li Class= "PatchOperationReplace" MayRequire="vanillaexpanded.vplantse">
				<xpath>Defs/ThingDef[defName="VCE_AppleTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~2.9</visualSizeRange>
				</value>
			</li>

			<li Class= "PatchOperationReplace" MayRequire="vanillaexpanded.vplantse">
				<xpath>Defs/ThingDef[defName="VCE_PeachTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~2.9</visualSizeRange>
				</value>
			</li>

			<li Class= "PatchOperationReplace" MayRequire="vanillaexpanded.vplantse">
				<xpath>Defs/ThingDef[defName="VCE_CherryTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~2.8</visualSizeRange>
				</value>
			</li>

			<li Class= "PatchOperationReplace" MayRequire="vanillaexpanded.vplantse">
				<xpath>Defs/ThingDef[defName="VCE_PlumTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.0</visualSizeRange>
				</value>
			</li>

			<li Class= "PatchOperationReplace" MayRequire="vanillaexpanded.vplantse">
				<xpath>Defs/ThingDef[defName="VCE_PearTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~2.9</visualSizeRange>
				</value>
			</li>

			<li Class= "PatchOperationReplace" MayRequire="vanillaexpanded.vplantse">
				<xpath>Defs/ThingDef[defName="VCE_BananaTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.0</visualSizeRange>
				</value>
			</li>

			<li Class= "PatchOperationReplace" MayRequire="vanillaexpanded.vplantse">
				<xpath>Defs/ThingDef[defName="VCE_OrangeTree"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~2.9</visualSizeRange>
				</value>
			</li>

		</operations>
	</Operation>

</Patch>