<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="AdaptiveStorageBase">
		<defName>ReelStorageMeatHook</defName>
		<label>meat hook</label>
		<graphicData>
			<texPath>Tier2/MeatHook/MeatHook</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(2.6,2.6)</drawSize>
			<drawRotated>false</drawRotated>
		</graphicData>
		<description>A specialized rack designed to hold raw meat and corpses for butchering or
			disposal. Items stored inside will not deteriorate over time and have no impact on the
			beauty of their surroundings, however you will still need to freeze them.
			\n\n&lt;color=#E5E54C&gt;Storage stats:&lt;/color&gt;
			Stack size total: 16
			Stack per tile: 8

			Allowed items: Raw meat, Fish, Corpses</description>
		<fillPercent>0.20</fillPercent>
		<uiIconPath>Tier2/MeatHook/MeatHook_UI</uiIconPath>
		<uiIconScale>1</uiIconScale>
		<size>(2,1)</size>
		<rotatable>true</rotatable>
		<defaultPlacingRot>North</defaultPlacingRot>
		<researchPrerequisites>
			<li>ReelMedievalStorage</li>
		</researchPrerequisites>
		<statBases>
			<MaxHitPoints>70</MaxHitPoints>
			<WorkToBuild>1100</WorkToBuild>
			<Beauty>0</Beauty>
			<Mass>6</Mass>
			<Flammability>1</Flammability>
		</statBases>
		<stuffCategories>
			<li>Woody</li>
			<li>Metallic</li>
		</stuffCategories>
		<costStuffCount>50</costStuffCount>
		<building>
			<preventDeteriorationOnTop>true</preventDeteriorationOnTop>
			<ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
			<maxItemsInCell>8</maxItemsInCell>
			<fixedStorageSettings>
				<filter>
					<specialFiltersToAllow>
						<li MayRequire="ludeon.rimworld.ideology">AllowVegetarian</li>
					</specialFiltersToAllow>
					<categories>
						<li>Corpses</li>
						<li MayRequire="vanillaexpanded.vcef">VCEF_RawFishCategory</li>
						<li>MeatRaw</li>
					</categories>
					<disallowedCategories>
						<li>ResourcesRaw</li>
						<li>Manufactured</li>
						<li>Medicine</li>
						<li>Drugs</li>
						<li>MortarShells</li>
						<li>PlantMatter</li>
					</disallowedCategories>
				</filter>
			</fixedStorageSettings>
			<defaultStorageSettings>
				<priority>Preferred</priority>
				<filter>
					<specialFiltersToDisallow>
						<li>AllowRotten</li>
					</specialFiltersToDisallow>
					<categories>
						<li>CorpsesAnimal</li>
					</categories>
				</filter>
			</defaultStorageSettings>
			<paintable>true</paintable>
		</building>
		<minifiedDef>MinifiedThing</minifiedDef>
		<thingCategories>
			<li>BuildingsFurniture</li>
		</thingCategories>
	</ThingDef>
</Defs>