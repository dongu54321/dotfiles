<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="AdaptiveStorageBase">
        <defName>ASF_ClothingRack</defName>
        <label>Clothing Rack</label>
        <graphicData>
            <texPath>ClothingRack/ClothingRack</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(3,2)</drawSize>
            <drawRotated>false</drawRotated>
        </graphicData>
        <description>A covered rack for storing clothing for easy, quick access and a tidy room.</description>
        <researchPrerequisites>
            <li>ComplexFurniture</li>
        </researchPrerequisites>
        <fillPercent>0.5</fillPercent>
        <uiIconPath>ClothingRack/ClothingRack_UI</uiIconPath>
        <uiIconScale>1</uiIconScale>
        <size>(2,1)</size>
        <rotatable>true</rotatable>
        <defaultPlacingRot>North</defaultPlacingRot>
        <statBases>
            <Beauty>1.5</Beauty>
            <MaxHitPoints>90</MaxHitPoints>
            <WorkToBuild>580</WorkToBuild>
            <Flammability>1.0</Flammability>
            <Mass>10</Mass>
        </statBases>
        <stuffCategories>
            <li>Metallic</li>
            <li>Woody</li>
            <li>Stony</li>
        </stuffCategories>
        <costStuffCount>50</costStuffCount>
        <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
        <building>
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
            <maxItemsInCell>10</maxItemsInCell>
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Apparel</li>
                    </categories>
                    <specialFiltersToDisallow>
                        <!-- Potential for filtering specific clothing types -->
                    </specialFiltersToDisallow>
                </filter>
            </fixedStorageSettings>
            <paintable>true</paintable>
        </building>
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsFurniture</li>
        </thingCategories>
    </ThingDef>
</Defs>