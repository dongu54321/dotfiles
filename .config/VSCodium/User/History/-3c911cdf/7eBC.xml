	<!-- Change size of trees scale -->
	
	<Operation Class= "PatchOperationSequence">
		<operations>
		
	<!-- Core Trees -->
		
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreePalm"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~3.0</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeCecropia"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~2.9</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeBamboo"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~2.5</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeBirch"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>	
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeDrago"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~3.3</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeMaple"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~3.2</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeOak"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~3.2</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationAdd" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreePoplar"]/plant[not(visualSizeRange)]</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeCocoa"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~2.9</visualSizeRange>
				</value>
			</li>	
			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeCypress"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.2</visualSizeRange>
				</value>
			</li>
			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld">
				<xpath>Defs/ThingDef[defName="Plant_TreeTeak"]/plant/visualSizeRange</xpath>
