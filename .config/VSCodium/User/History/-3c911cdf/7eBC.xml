         <xpath>Defs/ThingDef[defName="Plant_TreeAnima" or defName="Plant_TreeBamboo" or defName="Plant_TreeBirch" or defName="Plant_TreeCecropia" or defName="Plant_TreeCocoa" or defName="Plant_TreeCypress" or defName="Plant_TreeDrago" or defName="Plant_TreeGauranlen" or defName="Plant_TreeGrayPine" or defName="Plant_TreeMaple" or defName="Plant_TreeOak" or defName="Plant_TreePalm" or defName="Plant_TreePine" or defName="Plant_TreePolux" or defName="Plant_TreePoplar" or efName="Plant_TreeTeak" or defName="Plant_TreeWillow" or defName="BurnedTree" or defName="Plant_Witchwood" or defName="Plant_RatPalm"]</xpath>		 
