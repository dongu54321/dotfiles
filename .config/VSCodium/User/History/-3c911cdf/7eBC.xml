			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld.biotech">
				<xpath>Defs/ThingDef[defName="Plant_TreePolux"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>		
			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld.biotech">
				<xpath>Defs/ThingDef[defName="Plant_Witchwood"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.5</visualSizeRange>
				</value>
			</li>	
			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld.biotech">
				<xpath>Defs/ThingDef[defName="Plant_RatPalm"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~3.6</visualSizeRange>
				</value>
			</li>					
		</operations>		
	</Operation>	
			
</Patch>