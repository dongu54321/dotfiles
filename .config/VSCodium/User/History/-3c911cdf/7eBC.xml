				<value>
					<visualSizeRange>1.5~4.3</visualSizeRange>
				</value>
			</li>

	<!-- Royalty trees -->
	
			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld.royalty">
				<xpath>Defs/ThingDef[defName="Plant_TreeAnima"]/plant/visualSizeRange</xpath>
				<value>
					<visualSizeRange>1.5~2.8</visualSizeRange>
				</value>
			</li>
			
	<!-- Ideology trees -->
				
			<li Class= "PatchOperationReplace" MayRequire="ludeon.rimworld.ideology">
