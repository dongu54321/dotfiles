<?xml version="1.0" encoding="UTF-8"?> 
<Patch>
	<!-- Patching melee cooldown -->
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/StatDef[defName="MeleeCooldownFactor"]</xpath>
		<value>
			<skillNeedFactors>
				<li Class="SkillNeed_BaseBonus">
					<skill>Melee</skill>
					<baseValue>1.24</baseValue> <!-- 24% increase at lvl 0 -->
					<bonusPerLevel>-0.03</bonusPerLevel> <!-- decreases by 3% each level -->
				</li>
			</skillNeedFactors>
		</value>
	</Operation>
	<!-- Patching ranged cooldown -->
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/StatDef[defName="RangedCooldownFactor"]</xpath>
		<value>
			<skillNeedFactors>
				<li Class="SkillNeed_BaseBonus">
					<skill>Shooting</skill>
					<baseValue>1.24</baseValue> <!-- 24% increase at lvl 0 -->
					<bonusPerLevel>-0.03</bonusPerLevel> <!-- decreases by 3% each level -->
				</li>
			</skillNeedFactors>
		</value>
	</Operation>
