<Defs>
  <ThingDef ParentName="MeleeWeaponUltratech">
    <defName>CAT_MonoBastardSword</defName>
    <label>mono bastard sword</label>
    <description>A long blade infused with mechanites that maintain a mono-molecular cutting edge.</description>
    <soundInteract>Interact_MonoSword</soundInteract>
    <meleeHitSound>MeleeHit_MonoSword</meleeHitSound>
	<smeltable>false</smeltable>
    <equippedAngleOffset>5</equippedAngleOffset>
    <relicChance>3</relicChance>
	<statBases>
	  <MarketValue>2000</MarketValue>
	  <Mass>3</Mass>
	</statBases>
    <weaponClasses>
      <li>Melee</li>
      <li>MeleePiercer</li>
    </weaponClasses>
    <graphicData>
      <texPath>Things/Items/Equipment/WeaponMelee/MonoBastardSword</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>1.0</drawSize>
    </graphicData>
	<equippedStatOffsets>
      <MoveSpeed>-0.15</MoveSpeed>
    </equippedStatOffsets>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>point</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>32</power>
        <cooldownTime>2.2</cooldownTime>
        <armorPenetration>0.9</armorPenetration>
      </li>
      <li>
        <label>edge</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>32</power>
        <cooldownTime>2.2</cooldownTime>
        <armorPenetration>0.9</armorPenetration>
      </li>
    </tools>
  </ThingDef>

