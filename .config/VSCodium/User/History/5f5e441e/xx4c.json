{
    "security.workspace.trust.untrustedFiles": "open",
    "explorer.confirmDelete": false,
    "window.newWindowDimensions": "offset",
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.fontSize": 16,
    "terminal.integrated.fontFamily": "Space Mono for Powerline",
    "terminal.integrated.fontWeightBold": "700",
    "terminal.integrated.fontWeight": "540",
    "terminal.integrated.rightClickBehavior": "paste",
    "window.zoomLevel": 1,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "editor.fontVariations": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "terminal.external.linuxExec": "/bin/zsh",
    "files.associations": {
    "*.hujson": "jsonc"
    },
    "json.schemas": [{
        "fileMatch": ["*.hujson"],
        "schema": {
            "allowTrailingCommas": true
        }
    }
],
"git.enableSmartCommit": true,
"git.autofetch": true,
"terminal.integrated.scrollback": 2000,
"editor.renderWhitespace": "all",
"editor.multiCursorModifier": "ctrlCmd",
"debug.terminal.clearBeforeReusing": true,
"redhat.telemetry.enabled": false,
"[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
},
"terminal.integrated.cursorWidth": 1.2,
"editor.fontWeight": "normal",
"workbench.colorTheme": "Catppuccin Macchiato",
"editor.fontSize": 15,
"editor.fontFamily": "'JetBrains Mono', 'JetBrains Mono', JetBrains Mono",
"workbench.settings.applyToAllProfiles": [
    "editor.fontFamily"
],
"workbench.colorCustomizations": {
	"[Monokai]": {
		// "editor.background": "#25292b",
		"editor.background": "#151a1b",
        // "activityBar.background": "#1e3445",
        // "sideBar.background": "#1a4363",
        // "terminal.background": "#1a4368",
        "terminal.ansiBlue": "#d20ed1",
        // "sideBarSectionHeader.background": "#1f517c",
        // "tab.inactiveBackground": "#1e3468",
        "tab.activeBorder": "#0ed2c6",
        "tab.border": "#0ed2c6",
        "sideBar.border": "#0ed2c6",
        "terminal.border": "#0ed2c6",
        "widget.border": "#0ed2c6",
        "focusBorder": "#0ed2c6",
        "titleBar.border": "#0ed2c6",
        "dropdown.border": "#0ed2c6",
        "statusBar.border": "#0ed2c6",
        "panel.dropBorder": "#0ed2c6",
        "tab.activeBorderTop": "#0ed2c6",
        "debugToolBar.border": "#0ed2c6",
        "menu.border": "#0ed2c6",
        "sideBySideEditor.verticalBorder": "#0ed2c6",
        "sideBySideEditor.horizontalBorder": "#0ed2c6",
        "diffEditor.border": "#0ed2c6",
        "terminal.tab.activeBorder": "#0ed2c6",
        "panel.border": "#0ed2c6",

		// "foreground": "#008528",
	}
},
