function podmansystemd() {
	#cd ~/.config/systemd/user/ || exit
	podman generate systemd --name --new "$1" > ~/.config/systemd/user/container-"$1".service
	systemctl --user daemon-reload
	podman rm -f $1
	systemctl --user enable --now container-"$1".service
	#cd - || exit
}

