<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="AdaptiveStorageBase">
        <defName>ASF_MedCab</defName>
        <label>Medicine Cabinet</label>
        <graphicData>
            <texPath>MedCab/MedCab</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(2,1)</drawSize>
            <drawRotated>false</drawRotated>
        </graphicData>
        <description>A set of cabinets and shelves for stocking medicines and drugs. Recommended: keep an eye on children.</description>
        <researchPrerequisites>
            <li>ComplexFurniture</li>
        </researchPrerequisites>
        <fillPercent>0.4</fillPercent>
        <uiIconPath>MedCab/MedCab_UI</uiIconPath>
        <uiIconScale>1</uiIconScale>
        <size>(2,1)</size>
        <rotatable>true</rotatable>
        <defaultPlacingRot>South</defaultPlacingRot>
        <statBases>
            <Beauty>1</Beauty>
            <MaxHitPoints>25</MaxHitPoints>
            <Mass>8</Mass>
            <WorkToBuild>500</WorkToBuild>
            <Flammability>1.0</Flammability>
        </statBases>
        <stuffCategories>
            <li>Metallic</li>
            <li>Woody</li>
        </stuffCategories>
        <costStuffCount>60</costStuffCount>
        <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
        <building>
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
            <maxItemsInCell>8</maxItemsInCell>
            <fixedStorageSettings>
                <filter>
                    <categories>
                        <li>Medicine</li>
                        <li>Drugs</li>
                        <li>BodyParts</li>
                    </categories>
                    <thingDefs>
                        <li>Neutroamine</li>
                        <li>HemogenPack</li>
                    </thingDefs>
                </filter>
            </fixedStorageSettings>
            <paintable>true</paintable>
        </building>
        <minifiedDef>MinifiedThing</minifiedDef>
        <thingCategories>
            <li>BuildingsFurniture</li>
        </thingCategories>
    </ThingDef>
</Defs>
